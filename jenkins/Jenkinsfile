pipeline {
    agent any

    environment {
        DOCKERHUB = "yourdockerhubusername"
        COMPOSE_DIR = "docker"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh 'echo $PASS | docker login -u $USER --password-stdin'
                }
            }
        }

        stage('Build Images') {
            steps {
                dir("${COMPOSE_DIR}") {
                    sh '''
                    docker build -t $DOCKERHUB/telemedicine-backend ./backend
                    docker build -t $DOCKERHUB/telemedicine-frontend ./frontend
                    docker build -t $DOCKERHUB/telemedicine-nginx ./nginx
                    '''
                }
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                docker push $DOCKERHUB/telemedicine-backend
                docker push $DOCKERHUB/telemedicine-frontend
                docker push $DOCKERHUB/telemedicine-nginx
                '''
            }
        }

        stage('Deploy Containers') {
            steps {
                sh '''
                docker rm -f telemedicine_backend telemedicine_frontend telemedicine_nginx telemedicine_db || true
                cd docker
                docker compose up -d
                '''
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }

    post {
        success {
            echo "CI/CD Pipeline Completed 🚀"
        }
        failure {
            echo "Pipeline Failed ❌"
        }
    }
}
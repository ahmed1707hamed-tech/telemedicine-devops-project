pipeline {
    agent any

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Stop Old Containers') {
            steps {
                sh 'docker rm -f telemedicine_backend telemedicine_frontend telemedicine_nginx telemedicine_db || true'
            }
        }

        stage('Build Images') {
            steps {
                dir('docker') {
                    sh 'docker-compose build --parallel'
                }
            }
        }

        stage('Start Containers') {
            steps {
                dir('docker') {
                    sh 'docker-compose up -d backend frontend nginx db'
                }
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }
}